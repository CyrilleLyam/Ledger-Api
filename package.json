{
  "name": "ledger-api",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "migrate:latest": "node -r ts-node/register ./node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "node -r ts-node/register ./node_modules/knex/bin/cli.js migrate:rollback --knexfile knexfile.ts",
    "migrate:make": "node -r ts-node/register ./node_modules/knex/bin/cli.js migrate:make --knexfile knexfile.ts",
    "migrate:status": "node -r ts-node/register ./node_modules/knex/bin/cli.js migrate:status --knexfile knexfile.ts",
    "seed:make": "node -r ts-node/register ./node_modules/knex/bin/cli.js seed:make --knexfile knexfile.ts",
    "seed:run": "node -r ts-node/register ./node_modules/knex/bin/cli.js seed:run --knexfile knexfile.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "chhlat-logger": "^1.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "knex": "^3.2.9",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}